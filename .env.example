# Anthropic Claude API Key (필수 - AI 경로 추천에 사용)
# https://console.anthropic.com/settings/keys 에서 발급
VITE_ANTHROPIC_API_KEY=sk-ant-...

# 서울 열린데이터광장 API Key (선택 - 없으면 데모 데이터 사용)
# https://data.seoul.go.kr 에서 발급
VITE_SEOUL_API_KEY=

# Supabase (회원가입/보호자 연결 기능에 필요)
# https://supabase.com 에서 프로젝트 생성 후 Settings > API 에서 확인
VITE_SUPABASE_URL=https://xxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...
