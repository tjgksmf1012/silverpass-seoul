# Anthropic Claude API Key (서버 전용 - AI 경로 추천에 사용)
# Vercel 환경변수에도 같은 이름으로 등록하세요.
# https://console.anthropic.com/settings/keys 에서 발급
ANTHROPIC_API_KEY=sk-ant-...

# TMAP 보행자 경로안내 API Key (서버 전용 - 있으면 보행 턴바이턴을 우선 사용)
# https://openapi.sk.com / TMAP API에서 발급 후 Vercel 환경변수에 등록
TMAP_API_KEY=

# 서울 열린데이터광장 API Key
# 로컬 Vite 직접 호출용: VITE_SEOUL_API_KEY
# Vercel 서버리스 프록시용: SEOUL_API_KEY
# https://data.seoul.go.kr 에서 발급
VITE_SEOUL_API_KEY=
SEOUL_API_KEY=
SEOUL_SUBWAY_API_KEY=

# 공공데이터포털 API Key
# 로컬 Vite 직접 호출용: VITE_GONGGONG_API_KEY
# Vercel 서버리스 프록시용: GONGGONG_API_KEY
# https://www.data.go.kr 에서 발급
VITE_GONGGONG_API_KEY=
GONGGONG_API_KEY=

# 카카오 지도/장소 검색 JavaScript 키
# https://developers.kakao.com 에서 발급
VITE_KAKAO_MAP_KEY=

# ODsay 대중교통 API 키
# https://lab.odsay.com 에서 발급
VITE_ODSAY_API_KEY=

# Supabase (회원가입/보호자 연결 기능에 필요)
# https://supabase.com 에서 프로젝트 생성 후 Settings > API 에서 확인
VITE_SUPABASE_URL=https://xxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...
